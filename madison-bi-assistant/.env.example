# Databricks credentials for Madison BI Assistant
# Copy this to .env in your project root and fill in your PAT.
#
# The workspace hostname and SQL warehouse path are shared across the org.
# Your personal access token (PAT) is unique to you - generate one at:
#   Databricks workspace > User Settings > Developer > Access tokens

DATABRICKS_SERVER_HOSTNAME=adb-6242187004665047.7.azuredatabricks.net
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/6e7e26c4f1065740
DATABRICKS_ACCESS_TOKEN=<your-databricks-pat>
